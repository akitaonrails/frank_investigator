# Deploy configuration — copy to config/deploy.env and fill in values.
# This file is NOT committed to git.

# SSH connection to the production server
DEPLOY_HOST=192.168.0.145
DEPLOY_SSH_PORT=2022
DEPLOY_USER=akitaonrails

# Docker registry (Gitea)
# REGISTRY_HOST is used for docker push (from build machine)
REGISTRY_HOST=192.168.0.145
REGISTRY_PORT=3007
# REGISTRY_PULL_HOST is used on the server side for docker pull
REGISTRY_PULL_HOST=localhost

# Paths on the server
APP_DATA_DIR=/home/akitaonrails/frank_investigator
COMPOSE_FILE=/home/akitaonrails/docker/frank_investigator-docker-compose.yml

# App port exposed by the web container on the server
APP_PORT=3666

# Optional vector-search tuning
FRANK_INVESTIGATOR_VECTOR_SEARCH_ENABLED=true
FRANK_INVESTIGATOR_EMBEDDING_PROVIDER=openrouter
FRANK_INVESTIGATOR_EMBEDDING_MODEL=openai/text-embedding-3-small
FRANK_INVESTIGATOR_EMBEDDING_DIMENSIONS=1536
