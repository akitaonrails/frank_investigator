<%
  evidence_items = investigation.claim_assessments
    .includes(evidence_items: :article)
    .flat_map(&:evidence_items)
    .select { |ei| ei.article&.fetched_at.present? || ei.article&.published_at.present? }
    .sort_by { |ei| ei.article.published_at || ei.article.fetched_at }
%>

<article class="panel panel--wide">
  <h2><%= t("investigations.evidence_timeline.heading") %></h2>
  <% if evidence_items.any? %>
    <div class="timeline">
      <% evidence_items.each do |item| %>
        <% date = item.article.published_at || item.article.fetched_at %>
        <div class="timeline-entry">
          <div class="timeline-date"><%= l(date.to_date, format: :long) %></div>
          <div class="timeline-dot timeline-dot--<%= item.stance %>"></div>
          <div class="timeline-content">
            <p class="timeline-title"><%= item.article.title.presence || item.article.host %></p>
            <p class="timeline-meta">
              <span class="<%= badge_class_for(item.stance) %>"><%= te(:stance, item.stance) %></span>
              <span class="muted"><%= te(:source_kind, item.source_kind) %></span>
              <% claim = item.claim_assessment.claim if item.claim_assessment %>
              <% if claim&.claim_timestamp_end.present? && date.present? && date.to_date > claim.claim_timestamp_end %>
                <span class="badge badge--amber"><%= t("investigations.evidence_timeline.post_dates_claim") %></span>
              <% end %>
              <% if item.article.authority_tier != "unknown" %>
                <span class="muted">
                  <span class="has-popover">
                    <%= te(:authority_tier, item.article.authority_tier) %> <%= t("investigations.evidence_timeline.authority_suffix") %>
                    <span class="popover-content"><%= authority_tier_description(item.article.authority_tier) %></span>
                  </span>
                </span>
              <% end %>
            </p>
            <% if item.excerpt.present? %>
              <p class="timeline-excerpt muted"><%= item.excerpt.truncate(180) %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state"><%= t("investigations.evidence_timeline.empty") %></p>
  <% end %>
</article>
