<section class="summary-grid" id="summary_cards">
  <article class="metric-card">
    <p class="metric-label"><%= t("investigations.summary_cards.pipeline_status") %></p>
    <p class="metric-value"><span class="<%= badge_class_for(investigation.status) %>"><%= te(:pipeline_status, investigation.status) %></span></p>
  </article>
  <article class="metric-card">
    <p class="metric-label"><%= t("investigations.summary_cards.checkability") %></p>
    <p class="metric-value"><span class="<%= badge_class_for(investigation.checkability_status) %>"><%= te(:checkability_status, investigation.checkability_status) %></span></p>
  </article>
  <article class="metric-card">
    <p class="metric-label"><%= t("investigations.summary_cards.headline_bait") %></p>
    <p class="metric-value">
      <span class="score-bar <%= score_color_class(investigation.headline_bait_score) %>">
        <span class="score-bar__fill" style="width: <%= score_bar_width(investigation.headline_bait_score) %>%"></span>
      </span>
      <span class="metric-number"><%= score_percent(investigation.headline_bait_score) %></span>
    </p>
  </article>
  <article class="metric-card">
    <p class="metric-label"><%= t("investigations.summary_cards.overall_confidence") %></p>
    <p class="metric-value">
      <span class="score-bar <%= score_color_class(investigation.overall_confidence_score) %>">
        <span class="score-bar__fill" style="width: <%= score_bar_width(investigation.overall_confidence_score) %>%"></span>
      </span>
      <span class="metric-number"><%= score_percent(investigation.overall_confidence_score * 100) %></span>
    </p>
  </article>
</section>
