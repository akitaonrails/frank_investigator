<section class="summary-grid" id="summary_cards">
  <article class="metric-card">
    <p class="metric-label">Pipeline status</p>
    <p class="metric-value"><span class="<%= badge_class_for(investigation.status) %>"><%= investigation.status_badge %></span></p>
  </article>
  <article class="metric-card">
    <p class="metric-label">Checkability</p>
    <p class="metric-value"><span class="<%= badge_class_for(investigation.checkability_status) %>"><%= investigation.checkability_status.humanize %></span></p>
  </article>
  <article class="metric-card">
    <p class="metric-label">Headline bait score</p>
    <p class="metric-value"><%= score_percent(investigation.headline_bait_score) %></p>
  </article>
  <article class="metric-card">
    <p class="metric-label">Overall confidence</p>
    <p class="metric-value"><%= score_percent(investigation.overall_confidence_score * 100) %></p>
  </article>
</section>
