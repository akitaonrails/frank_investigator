<article class="panel panel--wide">
  <h2><%= t("investigations.source_graph.heading") %></h2>
  <% if links.any? %>
    <div class="source-graph-table">
      <table>
        <thead>
          <tr>
            <th><%= t("investigations.source_graph.source") %></th>
            <th><%= t("investigations.source_graph.kind") %></th>
            <th><%= t("investigations.source_graph.authority") %></th>
            <th><%= t("investigations.source_graph.role") %></th>
            <th><%= t("investigations.source_graph.status") %></th>
          </tr>
        </thead>
        <tbody>
          <% links.each do |link| %>
            <% target = link.target_article %>
            <tr>
              <td>
                <strong><%= link.anchor_text.presence || target.host %></strong>
                <br><span class="muted"><%= link.href.truncate(80) %></span>
              </td>
              <td><%= te(:source_kind, target.source_kind) %></td>
              <td>
                <span class="has-popover">
                  <%= te(:authority_tier, target.authority_tier) %>
                  (<%= score_percent(target.authority_score * 100) %>)
                  <span class="popover-content"><%= authority_tier_description(target.authority_tier) %></span>
                </span>
              </td>
              <td>
                <% if target.source_role != "unknown" %>
                  <span class="has-popover">
                    <%= te(:source_role, target.source_role) %>
                    <span class="popover-content"><%= source_role_description(target.source_role) %></span>
                  </span>
                <% else %>
                  <span class="muted"><%= t("investigations.source_graph.unknown_role") %></span>
                <% end %>
              </td>
              <td><span class="<%= badge_class_for(link.follow_status) %>"><%= te(:follow_status, link.follow_status) %></span></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Server-rendered SVG link graph %>
    <% if links.size >= 2 %>
      <%= render "source_graph_svg", links: links, investigation: investigation %>
    <% end %>
  <% else %>
    <p class="empty-state"><%= t("investigations.source_graph.empty") %></p>
  <% end %>
</article>
