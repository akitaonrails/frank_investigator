<%= tag.section id: dom_id(assessment), class: "claim-card" do %>
  <div class="claim-header">
    <span class="verdict-icon <%= assessment.verdict %>"><%= raw verdict_icon(assessment.verdict) %></span>
    <p class="claim-text"><%= assessment.claim.canonical_text %></p>
  </div>
  <p class="claim-meta">
    <span class="<%= badge_class_for(assessment.verdict) %>"><%= assessment.verdict.humanize %></span>
    <span>Confidence <%= score_percent(assessment.confidence_score * 100) %></span>
    <% if assessment.claim.claim_kind != "statement" %>
      <span class="badge badge--slate"><%= assessment.claim.claim_kind.humanize %></span>
    <% end %>
    <% if assessment.claim.time_scope.present? %>
      <span class="muted"><%= assessment.claim.time_scope %></span>
    <% end %>
    <% if assessment.stale_at.present? %>
      <span class="badge badge--amber">Stale</span>
    <% end %>
    <% if assessment.reassessment_count.to_i > 0 %>
      <span class="muted">Reassessed <%= assessment.reassessment_count %>&times;</span>
    <% end %>
  </p>
  <p><%= assessment.reason_summary %></p>

  <dl class="score-grid">
    <div>
      <dt>Authority</dt>
      <dd>
        <span class="score-bar score-bar--sm <%= score_color_class(assessment.authority_score) %>">
          <span class="score-bar__fill" style="width: <%= score_bar_width(assessment.authority_score) %>%"></span>
        </span>
        <span><%= score_percent(assessment.authority_score * 100) %></span>
      </dd>
    </div>
    <div>
      <dt>Independence</dt>
      <dd>
        <span class="score-bar score-bar--sm <%= score_color_class(assessment.independence_score) %>">
          <span class="score-bar__fill" style="width: <%= score_bar_width(assessment.independence_score) %>%"></span>
        </span>
        <span><%= score_percent(assessment.independence_score * 100) %></span>
      </dd>
    </div>
    <div>
      <dt>Timeliness</dt>
      <dd>
        <span class="score-bar score-bar--sm <%= score_color_class(assessment.timeliness_score) %>">
          <span class="score-bar__fill" style="width: <%= score_bar_width(assessment.timeliness_score) %>%"></span>
        </span>
        <span><%= score_percent(assessment.timeliness_score * 100) %></span>
      </dd>
    </div>
    <div>
      <dt>Conflict</dt>
      <dd>
        <span class="score-bar score-bar--sm <%= score_color_class(1.0 - assessment.conflict_score) %>">
          <span class="score-bar__fill" style="width: <%= score_bar_width(assessment.conflict_score) %>%"></span>
        </span>
        <span><%= score_percent(assessment.conflict_score * 100) %></span>
      </dd>
    </div>
  </dl>

  <% if assessment.disagreement_details.present? %>
    <details class="consensus-details">
      <summary>
        LLM consensus
        <% if assessment.unanimous? %>
          <span class="badge badge--green">Unanimous</span>
        <% else %>
          <span class="badge badge--amber">Disagreement</span>
        <% end %>
      </summary>
      <p class="muted"><%= assessment.disagreement_details %></p>
      <% if assessment.llm_interactions.any? %>
        <ul class="llm-verdicts-list">
          <% assessment.llm_interactions.where(interaction_type: :assessment, status: :completed).each do |interaction| %>
            <li>
              <strong><%= interaction.model_id %></strong>:
              <% if interaction.response_json.present? %>
                <span class="<%= badge_class_for(interaction.response_json['verdict'] || 'pending') %>"><%= (interaction.response_json['verdict'] || 'unknown').humanize %></span>
                <span class="muted"><%= score_percent((interaction.response_json['confidence_score'].to_f * 100)) %> confidence</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </details>
  <% end %>

  <% if assessment.verdict_snapshots.count > 1 %>
    <details class="consensus-details">
      <summary>
        Verdict history
        <% changes = assessment.verdict_changed_count %>
        <% if changes > 0 %>
          <span class="badge badge--amber">Changed <%= changes %>&times;</span>
        <% else %>
          <span class="badge badge--slate"><%= assessment.verdict_snapshots.count %> snapshots</span>
        <% end %>
      </summary>
      <ul class="llm-verdicts-list">
        <% assessment.verdict_snapshots.chronological.each do |snapshot| %>
          <li>
            <span class="muted"><%= snapshot.created_at.strftime("%Y-%m-%d %H:%M") %></span>
            <% if snapshot.previous_verdict.present? %>
              <span class="<%= badge_class_for(snapshot.previous_verdict) %>"><%= snapshot.previous_verdict.humanize %></span>
              &rarr;
            <% end %>
            <span class="<%= badge_class_for(snapshot.verdict) %>"><%= snapshot.verdict.humanize %></span>
            <span class="muted"><%= score_percent(snapshot.confidence_score.to_f * 100) %></span>
            <% if snapshot.previous_confidence_score.present? && snapshot.previous_confidence_score != snapshot.confidence_score %>
              <span class="muted">(was <%= score_percent(snapshot.previous_confidence_score.to_f * 100) %>)</span>
            <% end %>
            <span class="muted">&middot; <%= snapshot.evidence_count %> sources &middot; <%= snapshot.trigger.humanize %></span>
          </li>
        <% end %>
      </ul>
    </details>
  <% end %>

  <% if assessment.missing_evidence_summary.present? %>
    <p class="muted"><strong>Missing evidence:</strong> <%= assessment.missing_evidence_summary %></p>
  <% end %>

  <% if assessment.evidence_items.any? %>
    <details class="evidence-details">
      <summary>Evidence sources (<%= assessment.evidence_items.size %>)</summary>
      <ul class="evidence-list">
        <% assessment.evidence_items.order(authority_score: :desc, relevance_score: :desc).each do |item| %>
          <li>
            <span>
              <strong><%= item.article&.title.presence || item.source_url %></strong><br>
              <span class="muted">
                <%= item.source_kind.to_s.humanize %>
                <% if item.article&.source_role.present? && item.article.source_role != "unknown" %>
                  &middot;
                  <span class="has-popover">
                    <%= item.article.source_role.humanize %>
                    <span class="popover-content"><%= source_role_description(item.article.source_role) %></span>
                  </span>
                <% end %>
                &middot; relevance <%= score_percent(item.relevance_score * 100) %>
                &middot; authority <%= score_percent(item.authority_score * 100) %>
              </span>
              <% if item.excerpt.present? %>
                <br><span class="evidence-excerpt"><%= item.excerpt.truncate(200) %></span>
              <% end %>
            </span>
            <span class="<%= badge_class_for(item.stance) %>"><%= item.stance.humanize %></span>
          </li>
        <% end %>
      </ul>
    </details>
  <% end %>
<% end %>
