<% ctx = investigation.event_context %>
<% return unless ctx.present? && Array(ctx["related_investigations"]).size > 1 %>

<section class="border border-line rounded-3xl p-5 mb-4 border-l-4 border-l-ink bg-ink/2">
  <h3 class="font-bold mb-2"><%= t("investigations.event_context.heading") %></h3>
  <p class="text-muted mb-3 text-sm"><%= t("investigations.event_context.subheading", count: Array(ctx["related_investigations"]).size) %></p>

  <% if ctx["composite_timeline"].present? %>
    <div class="mb-4">
      <h4 class="text-sm font-semibold mb-1"><%= t("investigations.event_context.composite_timeline") %></h4>
      <div class="text-sm leading-relaxed"><%= render_reason_summary(ctx["composite_timeline"]) %></div>
    </div>
  <% end %>

  <% omissions = Array(ctx["critical_omissions"]) %>
  <% if omissions.any? %>
    <div class="mb-4">
      <h4 class="text-sm font-semibold text-verdict-red mb-1"><%= t("investigations.event_context.critical_omissions") %></h4>
      <ul class="list-none p-0 m-0 space-y-1">
        <% omissions.each do |o| %>
          <li class="flex items-start gap-2 text-sm">
            <span class="text-verdict-red shrink-0 mt-0.5">&#9888;</span>
            <span><%= render_reason_summary(o) %></span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if ctx["narrative_assessment"].present? %>
    <div class="mb-4">
      <h4 class="text-sm font-semibold mb-1"><%= t("investigations.event_context.narrative_assessment") %></h4>
      <div class="text-sm text-muted"><%= render_reason_summary(ctx["narrative_assessment"]) %></div>
    </div>
  <% end %>

  <% this_host = investigation.root_article&.host %>
  <% related = Array(ctx["related_investigations"]) %>

  <details class="mt-3 p-3 bg-black/2 rounded-xl border border-line/40">
    <summary class="cursor-pointer text-sm text-muted hover:text-ink">
      <%= t("investigations.event_context.coverage_comparison") %> (<%= related.size %> <%= t("investigations.event_context.articles") %>)
    </summary>
    <div class="mt-3 grid gap-3">
      <% related.each do |inv_data| %>
        <% is_current = inv_data["slug"] == investigation.slug %>
        <% included = Array(inv_data["facts_included"]) %>
        <% omitted = Array(inv_data["facts_omitted"]) %>
        <details class="rounded-lg border <%= is_current ? 'border-ink/20 bg-ink/3' : 'border-line/40 bg-card/40' %>" <%= "open" if is_current %>>
          <summary class="cursor-pointer list-none p-3">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <% if is_current %>
                    <span class="text-xs font-bold uppercase tracking-wide text-muted"><%= t("investigations.event_context.this_article") %></span>
                  <% else %>
                    <span class="text-sm text-ink"><%= inv_data["host"] %></span>
                  <% end %>
                  <span class="<%= badge_class_for(inv_data["quality"] == "strong" ? "supported" : inv_data["quality"] == "weak" ? "disputed" : "mixed") %> text-xs"><%= inv_data["quality"]&.capitalize %></span>
                </div>
                <p class="text-xs text-muted"><%= inv_data["title"] %></p>
              </div>
              <div class="text-right text-xs text-muted shrink-0">
                <% if included.any? %>
                  <div><%= t("investigations.event_context.facts_included") %>: <%= included.size %></div>
                <% end %>
                <% if omitted.any? %>
                  <div><%= t("investigations.event_context.facts_omitted") %>: <%= omitted.size %></div>
                <% end %>
              </div>
            </div>
          </summary>
          <div class="px-3 pb-3 pt-0 border-t border-line/30">
            <% unless is_current %>
              <p class="pt-3 text-sm">
                <%= link_to investigation_path(inv_data["slug"]), class: "text-ink hover:underline" do %>
                  <%= t("investigations.event_context.open_investigation") %>
                <% end %>
              </p>
            <% end %>

            <% if included.any? %>
              <div class="pt-3">
                <h5 class="text-xs font-semibold uppercase tracking-wide text-verdict-green mb-2"><%= t("investigations.event_context.facts_included") %></h5>
                <ul class="space-y-1">
                  <% included.each do |fact| %>
                    <li class="text-sm text-ink flex items-start gap-2">
                      <span class="text-verdict-green shrink-0 mt-0.5">&#10003;</span>
                      <span><%= render_reason_summary(fact) %></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <% if omitted.any? %>
              <div class="pt-3">
                <h5 class="text-xs font-semibold uppercase tracking-wide text-verdict-red mb-2"><%= t("investigations.event_context.facts_omitted") %></h5>
                <ul class="space-y-1">
                  <% omitted.each do |fact| %>
                    <li class="text-sm text-ink flex items-start gap-2">
                      <span class="text-verdict-red shrink-0 mt-0.5">&#10007;</span>
                      <span><%= render_reason_summary(fact) %></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>
        </details>
      <% end %>
    </div>
  </details>
</section>
