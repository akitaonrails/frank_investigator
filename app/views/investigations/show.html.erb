<% content_for :title, t(".title") %>

<%= turbo_stream_from @investigation %>

<main class="page-shell">
  <header class="analysis-header">
    <div>
      <p class="eyebrow"><%= t(".eyebrow") %></p>
      <h1><%= t(".heading") %></h1>
      <p class="analysis-url"><%= @investigation.normalized_url %></p>
    </div>

    <%= form_with url: root_path, method: :get, class: "analysis-form", local: true do |form| %>
      <%= form.url_field :url, value: @investigation.normalized_url, class: "url-input", required: true %>
      <%= form.submit t(".rerun"), class: "submit-button submit-button--small" %>
    <% end %>
  </header>

  <% if @failure_info.present? %>
    <section class="panel panel--error">
      <h2><%= t(".investigation_failed") %></h2>
      <p><%= @failure_info[:user_message] %></p>
      <details>
        <summary><%= t(".technical_details") %></summary>
        <p class="muted">
          <%= t(".step_label") %> <%= @failure_info[:step_name] %><br>
          <% if @failure_info[:error_class].present? %>
            <%= t(".error_label") %> <%= @failure_info[:error_class] %><br>
          <% end %>
          <% if @failure_info[:error_message].present? %>
            <%= t(".message_label") %> <%= @failure_info[:error_message].truncate(300) %>
          <% end %>
        </p>
      </details>
      <p>
        <%= link_to t(".try_again"), root_path(url: @investigation.normalized_url), class: "submit-button submit-button--small" %>
      </p>
    </section>
  <% end %>

  <%= render "summary_cards", investigation: @investigation %>

  <% if @investigation.headline_bait_score > 0 %>
    <%= render "headline_bait", investigation: @investigation %>
  <% end %>

  <%= render "rhetorical_analysis", investigation: @investigation %>

  <section class="content-grid">
    <%= render "root_article_panel", root_article: @root_article %>

    <article class="panel" id="checkable_claims">
      <h2><%= t(".what_we_checked") %></h2>
      <% if @checkable_claims.any? %>
        <% @checkable_claims.each do |assessment| %>
          <%= render "claim_assessment", assessment: %>
        <% end %>
      <% elsif @investigation.completed? && @investigation.not_checkable? %>
        <p class="empty-state"><%= t(".no_checkable_claims") %></p>
      <% else %>
        <p class="empty-state"><%= t(".claims_pending") %></p>
      <% end %>
    </article>

    <article class="panel" id="uncheckable_claims">
      <h2><%= t(".what_we_could_not_check") %></h2>
      <% if @uncheckable_claims.any? %>
        <% @uncheckable_claims.each do |assessment| %>
          <section class="claim-card">
            <p class="claim-text"><%= assessment.claim.canonical_text %></p>
            <p class="claim-meta">
              <span class="<%= badge_class_for(assessment.checkability_status) %>"><%= te(:checkability_status, assessment.checkability_status) %></span>
              <% if assessment.claim.claim_kind != "statement" %>
                <span class="badge badge--slate"><%= te(:claim_kind, assessment.claim.claim_kind) %></span>
              <% end %>
            </p>
            <p class="muted"><%= assessment.reason_summary.presence || t(".default_uncheckable_reason") %></p>
          </section>
        <% end %>
      <% else %>
        <p class="empty-state"><%= t(".uncheckable_pending") %></p>
      <% end %>
    </article>

    <%= render "evidence_timeline", investigation: @investigation %>

    <%= render "source_graph", links: @links, investigation: @investigation %>

    <%= render "pipeline_panel", steps: @pipeline_steps %>
  </section>
</main>
