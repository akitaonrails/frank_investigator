<% content_for :title, t(".title") %>

<%= turbo_stream_from @investigation %>

<main class="w-full max-w-[1120px] mx-auto px-4 py-8 pb-16">
  <header class="mb-8">
    <p class="mb-3 text-muted text-xs font-semibold tracking-[0.18em] uppercase"><%= t(".eyebrow") %></p>
    <h1 class="font-serif text-[clamp(2rem,4vw,3rem)] leading-[1.1] font-extrabold tracking-tight mb-2"><%= t(".heading") %></h1>
    <a href="<%= @investigation.normalized_url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-muted text-sm hover:text-ink transition-colors">
      <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 3.5H3a1 1 0 00-1 1V13a1 1 0 001 1h8.5a1 1 0 001-1V9.5M9.5 2.5h4m0 0v4m0-4L8 8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <%= t(".view_original") %>
    </a>
  </header>

  <% if @failure_info.present? %>
    <section class="border border-line bg-verdict-red/4 rounded-3xl p-5 mb-4 border-l-4 border-l-verdict-red">
      <h2 class="text-verdict-red text-lg font-bold"><%= t(".investigation_failed") %></h2>
      <p><%= @failure_info[:user_message] %></p>
      <details class="my-2">
        <summary class="cursor-pointer text-muted text-sm hover:text-ink"><%= t(".technical_details") %></summary>
        <p class="text-muted">
          <%= t(".step_label") %> <%= @failure_info[:step_name] %><br>
          <% if @failure_info[:error_class].present? %>
            <%= t(".error_label") %> <%= @failure_info[:error_class] %><br>
          <% end %>
          <% if @failure_info[:error_message].present? %>
            <%= t(".message_label") %> <%= @failure_info[:error_message].truncate(300) %>
          <% end %>
        </p>
      </details>
    </section>
  <% end %>

  <%= render "summary_cards", investigation: @investigation %>

  <% unless @investigation.completed? || @investigation.failed? %>
    <%
      completed_count = @investigation.pipeline_steps.where(status: "completed").count
      total_count = @investigation.pipeline_steps.count
      progress_pct = total_count > 0 ? (completed_count.to_f / total_count * 100).round : 0
    %>
    <section class="mb-6 px-5 py-4 border border-line rounded-2xl bg-card" id="progress_banner">
      <div class="flex items-center justify-between gap-3 mb-2">
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-verdict-amber animate-spin shrink-0" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="50 20" stroke-linecap="round"/>
          </svg>
          <span class="text-sm font-medium">
            <%= t("investigations.progress.analyzing") %>
            <% if (step = active_step_name(@investigation)) %>
              &mdash; <%= step %>
            <% end %>
          </span>
        </div>
        <span class="text-muted text-sm font-medium tabular-nums"><%= completed_count %>/<%= total_count %></span>
      </div>
      <div class="w-full h-1.5 bg-line/40 rounded-full overflow-hidden">
        <div class="h-full rounded-full bg-verdict-amber transition-all duration-500 ease-out" style="width: <%= progress_pct %>%"></div>
      </div>
    </section>
  <% end %>

  <% if @investigation.headline_bait_score > 0 %>
    <%= render "headline_bait", investigation: @investigation %>
  <% end %>

  <%= render "rhetorical_analysis", investigation: @investigation %>

  <%= render "contextual_gaps", investigation: @investigation %>

  <%= render "investigation_summary", investigation: @investigation %>

  <section class="space-y-4">
    <%= render "root_article_panel", root_article: @root_article %>

    <article class="border border-line bg-card backdrop-blur-sm rounded-2xl p-5 shadow-sm" id="checkable_claims">
      <h2 class="text-base font-semibold mb-4 uppercase tracking-wide text-muted"><%= t(".what_we_checked") %></h2>
      <% if @checkable_claims.any? %>
        <% @checkable_claims.each do |assessment| %>
          <%= render "claim_assessment", assessment: %>
        <% end %>
      <% elsif @investigation.completed? && @investigation.not_checkable? %>
        <p class="text-muted"><%= t(".no_checkable_claims") %></p>
      <% else %>
        <div class="space-y-4">
          <div class="flex items-center gap-2.5 text-muted text-sm">
            <svg class="w-4 h-4 animate-spin shrink-0" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="50 20" stroke-linecap="round"/>
            </svg>
            <span><%= t(".claims_pending") %></span>
          </div>
          <% 3.times do %>
            <div class="pt-4 border-t border-line/60 space-y-2">
              <div class="h-4 w-3/4 rounded progress-shimmer"></div>
              <div class="h-3 w-1/2 rounded progress-shimmer"></div>
              <div class="flex gap-2">
                <div class="h-6 w-16 rounded-full progress-shimmer"></div>
                <div class="h-6 w-20 rounded-full progress-shimmer"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </article>

    <article class="border border-line bg-card backdrop-blur-sm rounded-2xl p-5 shadow-sm" id="uncheckable_claims">
      <h2 class="text-base font-semibold mb-4 uppercase tracking-wide text-muted"><%= t(".what_we_could_not_check") %></h2>
      <% if @uncheckable_claims.any? %>
        <% @uncheckable_claims.each do |assessment| %>
          <section class="pt-4 border-t border-line/60 first:pt-0 first:border-t-0">
            <p class="text-base leading-relaxed"><%= assessment.claim.canonical_text %></p>
            <p class="flex flex-wrap gap-3 text-muted">
              <span class="<%= badge_class_for(assessment.checkability_status) %>"><%= te(:checkability_status, assessment.checkability_status) %></span>
              <% if assessment.claim.claim_kind != "statement" %>
                <span class="<%= badge_class_for("not_checkable") %>"><%= te(:claim_kind, assessment.claim.claim_kind) %></span>
              <% end %>
            </p>
            <p class="text-muted"><%= assessment.reason_summary.presence || t(".default_uncheckable_reason") %></p>
          </section>
        <% end %>
      <% elsif @investigation.completed? || @investigation.failed? %>
        <p class="text-muted"><%= t(".no_uncheckable_claims") %></p>
      <% else %>
        <div class="flex items-center gap-2.5 text-muted text-sm">
          <svg class="w-4 h-4 animate-spin shrink-0" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="50 20" stroke-linecap="round"/>
          </svg>
          <span><%= t(".uncheckable_pending") %></span>
        </div>
        <% 2.times do %>
          <div class="pt-3 border-t border-line/60 space-y-2">
            <div class="h-4 w-2/3 rounded progress-shimmer"></div>
            <div class="h-3 w-1/3 rounded progress-shimmer"></div>
          </div>
        <% end %>
      <% end %>
    </article>

    <%= render "evidence_timeline", investigation: @investigation %>

    <%= render "source_graph", links: @links, investigation: @investigation %>

    <%= render "pipeline_panel", steps: @pipeline_steps %>
  </section>
</main>
