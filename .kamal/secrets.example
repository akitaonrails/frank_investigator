# Kamal secrets — copy to .kamal/secrets and fill in real values.
# .kamal/secrets, .kamal/secrets.<destination>, and .kamal/secrets-common are gitignored and must never be committed.

RAILS_MASTER_KEY=$(cat config/master.key)

KAMAL_REGISTRY_USERNAME=your-github-username
KAMAL_REGISTRY_PASSWORD=ghp_your_github_pat

OPENROUTER_API_KEY=sk-or-v1-your-key
OPENAI_API_KEY=sk-proj-your-key            # Optional: use with FRANK_INVESTIGATOR_EMBEDDING_PROVIDER=openai
FRANK_INVESTIGATOR_OPENROUTER_MODELS=anthropic/claude-sonnet-4-6,openai/gpt-5.4,google/gemini-3.1-pro-preview
FRANK_AUTH_SECRET=generate-with-openssl-rand-hex-32
ALLOWED_HOST=investigator.themakitachronicles.com
JOBS_AUTH_PASSWORD=generate-with-openssl-rand-hex-16
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
