# Required
OPENROUTER_API_KEY=your-openrouter-api-key

# Production security
ALLOWED_HOST=frank.example.com
RAILS_MASTER_KEY=your-master-key
JOBS_AUTH_USER=admin
JOBS_AUTH_PASSWORD=change-me-in-production
FRANK_AUTH_SECRET=generate-a-long-random-secret-here
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Error reporting (optional, local DB always enabled)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# HONEYBADGER_API_KEY=your-honeybadger-api-key

# Optional tuning
CHROMIUM_PATH=chromium
LLM_TIMEOUT_SECONDS=120
QUARANTINED_MODELS=
FRANK_INVESTIGATOR_MAX_LINK_DEPTH=1
FRANK_INVESTIGATOR_FETCHER_CLASS=Fetchers::ChromiumFetcher
FRANK_INVESTIGATOR_LLM_CLIENT_CLASS=Llm::RubyLlmClient
FRANK_INVESTIGATOR_OPENROUTER_MODELS=anthropic/claude-sonnet-4-6,openai/gpt-4.1-mini,google/gemini-2.5-pro-preview-03-25

# Server
PORT=3000
WEB_CONCURRENCY=1
RAILS_MAX_THREADS=3
RAILS_LOG_LEVEL=info
SOLID_QUEUE_IN_PUMA=1
JOB_CONCURRENCY=3
